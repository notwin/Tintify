#!/bin/bash
# tintify — CLI wrapper for Tintify.app
# 真正的实现在 app 二进制的 headless 分支里（Tintify cli ...），
# 这里只负责找到二进制并转发参数。

APP_BINARY="/Applications/Tintify.app/Contents/MacOS/Tintify"

if [[ ! -x "$APP_BINARY" ]]; then
    echo "错误: 未找到 /Applications/Tintify.app，请先安装 Tintify。" >&2
    exit 1
fi

exec "$APP_BINARY" cli "$@"
