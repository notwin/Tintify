#!/bin/bash
# tintify — CLI interface for Tintify theme manager
# Usage: tintify set <theme-id> | list | current | tools

set -e

APP_PATH="/Applications/Tintify.app"
BINARY="$APP_PATH/Contents/MacOS/Tintify"
PLIST_BUDDY="/usr/libexec/PlistBuddy"
DEFAULTS="defaults read com.notwin.Tintify"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

usage() {
    echo -e "${BOLD}tintify${NC} — 终端主题管理器 CLI"
    echo ""
    echo -e "${BOLD}用法:${NC}"
    echo "  tintify set <theme-id>    切换主题"
    echo "  tintify list              列出所有主题"
    echo "  tintify current           显示当前主题"
    echo "  tintify tools             显示工具状态"
    echo "  tintify help              显示帮助"
    echo ""
    echo -e "${BOLD}示例:${NC}"
    echo "  tintify set catppuccin-mocha"
    echo "  tintify set nord"
    echo "  tintify list"
}

# Theme registry (id:name:category:appearance)
THEMES=(
    "catppuccin-mocha:Catppuccin Mocha:热门推荐:dark"
    "catppuccin-macchiato:Catppuccin Macchiato:热门推荐:dark"
    "catppuccin-frappe:Catppuccin Frappe:热门推荐:dark"
    "catppuccin-latte:Catppuccin Latte:热门推荐:light"
    "dracula:Dracula:热门推荐:dark"
    "solarized-dark:Solarized Dark:热门推荐:dark"
    "solarized-light:Solarized Light:热门推荐:light"
    "monokai:Monokai:经典永恒:dark"
    "one-dark:One Dark:经典永恒:dark"
    "one-light:One Light:经典永恒:light"
    "gruvbox-dark:Gruvbox Dark:经典永恒:dark"
    "gruvbox-light:Gruvbox Light:经典永恒:light"
    "nord:Nord:经典永恒:dark"
    "tokyo-night:Tokyo Night:新锐之选:dark"
    "tokyo-night-light:Tokyo Night Light:新锐之选:light"
    "rose-pine:Rosé Pine:新锐之选:dark"
    "rose-pine-moon:Rosé Pine Moon:新锐之选:dark"
    "rose-pine-dawn:Rosé Pine Dawn:新锐之选:light"
    "kanagawa-wave:Kanagawa Wave:新锐之选:dark"
    "kanagawa-dragon:Kanagawa Dragon:新锐之选:dark"
    "kanagawa-lotus:Kanagawa Lotus:新锐之选:light"
    "everforest-dark:Everforest Dark:新锐之选:dark"
    "neon-city:Neon City:Tintify 原创:dark"
    "ink-bamboo:墨竹:Tintify 原创:dark"
    "aurora:极光:Tintify 原创:dark"
)

cmd_list() {
    local current
    current=$(defaults read com.notwin.Tintify currentThemeId 2>/dev/null || echo "")
    local last_category=""

    for entry in "${THEMES[@]}"; do
        IFS=':' read -r id name category appearance <<< "$entry"
        if [[ "$category" != "$last_category" ]]; then
            [[ -n "$last_category" ]] && echo ""
            echo -e "${BOLD}${category}${NC}"
            last_category="$category"
        fi
        local marker="  "
        local color=""
        if [[ "$id" == "$current" ]]; then
            marker="✓ "
            color="${GREEN}"
        fi
        local badge=""
        if [[ "$appearance" == "light" ]]; then
            badge=" ${DIM}(浅色)${NC}"
        fi
        echo -e "  ${color}${marker}${id}${NC} — ${name}${badge}"
    done
}

cmd_current() {
    local current
    current=$(defaults read com.notwin.Tintify currentThemeId 2>/dev/null || echo "")
    if [[ -z "$current" ]]; then
        echo -e "${YELLOW}未设置主题${NC}"
        return 1
    fi
    for entry in "${THEMES[@]}"; do
        IFS=':' read -r id name category appearance <<< "$entry"
        if [[ "$id" == "$current" ]]; then
            echo -e "${GREEN}${name}${NC} (${id}) — ${category}"
            return 0
        fi
    done
    echo -e "${YELLOW}${current}${NC} (未知主题)"
}

cmd_set() {
    local theme_id="$1"
    if [[ -z "$theme_id" ]]; then
        echo -e "${RED}错误: 请指定主题 ID${NC}"
        echo "用法: tintify set <theme-id>"
        echo "运行 'tintify list' 查看可用主题"
        return 1
    fi

    # Validate theme exists
    local found=false
    local theme_name=""
    for entry in "${THEMES[@]}"; do
        IFS=':' read -r id name category appearance <<< "$entry"
        if [[ "$id" == "$theme_id" ]]; then
            found=true
            theme_name="$name"
            break
        fi
    done

    if [[ "$found" != "true" ]]; then
        echo -e "${RED}错误: 未找到主题 '${theme_id}'${NC}"
        echo "运行 'tintify list' 查看可用主题"
        return 1
    fi

    # Check if Tintify app is running
    if pgrep -f "Tintify" > /dev/null 2>&1; then
        # App is running — use open with URL scheme or restart approach
        # Kill and relaunch with the new theme set via defaults
        defaults write com.notwin.Tintify currentThemeId "$theme_id"

        # Trigger the app to re-apply by restarting it
        pkill -f "Tintify.app" 2>/dev/null || true
        sleep 1
        open "$APP_PATH"
        echo -e "${GREEN}✓ 已切换到 ${BOLD}${theme_name}${NC}"
        echo -e "${DIM}  Tintify 已重启并应用新主题${NC}"
    else
        # App not running — set defaults and launch
        defaults write com.notwin.Tintify currentThemeId "$theme_id"
        open "$APP_PATH"
        echo -e "${GREEN}✓ 已切换到 ${BOLD}${theme_name}${NC}"
        echo -e "${DIM}  Tintify 已启动并应用新主题${NC}"
    fi
}

cmd_tools() {
    local disabled
    disabled=$(defaults read com.notwin.Tintify disabledTools 2>/dev/null || echo "()")

    local tools=("ghostty" "starship" "bat" "fzf" "delta" "eza" "lazygit" "tmux" "vim" "zsh-syntax-highlighting")

    echo -e "${BOLD}工具状态${NC}"
    echo ""
    for tool in "${tools[@]}"; do
        if echo "$disabled" | grep -q "\"$tool\""; then
            echo -e "  ${RED}✗${NC} ${DIM}${tool}${NC} — 已禁用"
        else
            echo -e "  ${GREEN}✓${NC} ${tool} — 已启用"
        fi
    done
}

# Main
case "${1:-}" in
    set)
        cmd_set "$2"
        ;;
    list)
        cmd_list
        ;;
    current)
        cmd_current
        ;;
    tools)
        cmd_tools
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        echo -e "${RED}未知命令: $1${NC}"
        usage
        exit 1
        ;;
esac
